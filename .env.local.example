# Exemplo de variáveis de ambiente para desenvolvimento local
# Preencha com os valores fornecidos por `supabase start` ou pelo projeto remoto

# URLs e chaves para o cliente web
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=anonkey_replace_me

# Alternativas (Vite):
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=anonkey_replace_me

# String de conexão Postgres para psql (usado para aplicar migrations)
# Ex: postgres://postgres:postgres@127.0.0.1:5432/postgres
SUPABASE_DB_URL=postgres://postgres:postgres@127.0.0.1:5432/postgres
# Copy to .env.local and fill values to run locally
# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional: set to 1 to enable mock behaviors (if implemented)
VITE_USE_MOCK=0
